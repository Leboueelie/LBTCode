{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "include": ["src/**", "desktop/**"],
    "ignore": [
      "**/dist",
      "**/dist-backend",
      "**/dist-desktop",
      "**/.claude/workflows",
      "**/*.workflow.mjs",
      "**/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noAssignInExpressions": "off",
        "noDoubleEquals": "off",
        "noRedeclare": "off",
        "noImplicitAnyLet": "off",
        "noGlobalIsNan": "off",
        "noFallthroughSwitchClause": "off",
        "noShadowRestrictedNames": "off",
        "noArrayIndexKey": "off",
        "noConsole": "off",
        "noConfusingLabels": "off"
      },
      "style": {
        "useConst": "off",
        "noNonNullAssertion": "off",
        "noParameterAssign": "off",
        "useDefaultParameterLast": "off",
        "noUnusedTemplateLiteral": "off",
        "useTemplate": "off",
        "useNumberNamespace": "off",
        "useNodejsImportProtocol": "off",
        "useImportType": "off",
        "noUselessElse": "off",
        "noArguments": "off"
      },
      "complexity": {
        "noForEach": "off",
        "noBannedTypes": "off",
        "noUselessConstructor": "off",
        "noStaticOnlyClass": "off",
        "useOptionalChain": "off",
        "noUselessSwitchCase": "off",
        "noUselessFragments": "off",
        "noUselessTernary": "off",
        "noUselessLoneBlockStatements": "off",
        "noUselessEmptyExport": "off",
        "useArrowFunction": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedImports": "off",
        "useExhaustiveDependencies": "off",
        "noSwitchDeclarations": "off",
        "noUnreachable": "off",
        "useHookAtTopLevel": "off",
        "noVoidTypeReturn": "off",
        "noConstantCondition": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedPrivateClassMembers": "off"
      },
      "a11y": {
        "recommended": false
      },
      "performance": {
        "noDelete": "off"
      },
      "nursery": {
        "recommended": false
      }
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "parser": {}
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "arrowParentheses": "asNeeded",
      "trailingCommas": "es5"
    }
  },
  "overrides": [
    {
      "include": ["**/*.tsx"],
      "javascript": {
        "formatter": {
          "semicolons": "always"
        }
      },
      "formatter": {
        "lineWidth": 120
      }
    }
  ],
  "assists": {
    "enabled": false
  }
}
